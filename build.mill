//| mvnDeps: ["org.chipsalliance:firtool-resolver_2.13:2.0.1"]

import mill.*, scalalib.*

// Note: This project requires .mill-jvm-opts file containing:
//   -Dchisel.project.root=${PWD}
// This is needed because Chisel needs to know the project root directory
// to properly generate and handle test directories and output files.
// See: https://github.com/com-lihaoyi/mill/issues/3840

val pwd                 = os.Path(sys.env("MILL_WORKSPACE_ROOT"))
val defaultScalaVersion = "2.13.17"

object deps {
    val scala         = defaultScalaVersion
    val chiselVersion = "7.3.0"

    val chisel       = mvn"org.chipsalliance::chisel:$chiselVersion"
    val chiselPlugin = mvn"org.chipsalliance:::chisel-plugin:$chiselVersion"
    val scalatest    = mvn"org.scalatest::scalatest:3.2.19"
}

trait CommonModule extends ScalaModule {
    override def scalaVersion = deps.scala

    override def scalacOptions = Seq("-Ymacro-annotations")
}

trait HasChisel extends ScalaModule {
    override def mvnDeps             = Seq(deps.chisel)
    override def scalacPluginMvnDeps = Seq(deps.chiselPlugin)
}

trait CommonNS extends SbtModule with CommonModule with HasChisel

object DifftestLib extends CommonNS {
    override def moduleDir = pwd / "difftest"
    override def scalacOptions = Seq(
        "-Ymacro-annotations",
        "-feature",
        "-language:reflectiveCalls"
    )
}

object `IonSoC` extends CommonNS {
    override def moduleDir = pwd

    override def scalacOptions = Seq(
        "-language:reflectiveCalls",
        "-deprecation",
        "-feature",
        "-Xcheckinit",
        "-Ymacro-annotations"
    )

    override def moduleDeps = super.moduleDeps ++ Seq(DifftestLib)

    object test extends SbtTests with TestModule.ScalaTest {
        override def mvnDeps = super.mvnDeps() ++ Seq(deps.scalatest)
    }

}
